# Required everywhere
STEAM_API_KEY=

# Required in production (set via host env, not committed). In local dev,
# leave blank to use a persistent secret in .data/session-secret.
SESSION_SECRET=

# Local dev defaults. Override in production with your deployed origin
# (e.g. https://steam-common-games.vercel.app). Both are required for
# any non-localhost deployment - the server fails closed otherwise.
STEAM_AUTH_ORIGIN=http://127.0.0.1:5174
APP_CLIENT_ORIGIN=http://127.0.0.1:5173

# Set to 1 when running behind a reverse proxy (Vercel, nginx, Cloudflare).
# Leave unset for direct localhost dev.
TRUST_PROXY=

# Local API port (used by `npm run dev:api`). Ignored on Vercel.
PORT=5174
